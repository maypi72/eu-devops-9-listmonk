# Environment variables for Terraform
# Copy this file to .env and fill in your values

# AWS Configuration
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_ENDPOINT=http://localhost:31566
ENVIRONMENT=development

# S3 Bucket Configuration
POSTGRES_BACKUP_BUCKET_NAME=listmonk-postgres-backups

# ECR Repository Configuration
LISTMONK_ECR_REPO_NAME=listmonk/app
POSTGRES_ECR_REPO_NAME=listmonk/postgres

# PostgreSQL Configuration
POSTGRES_SECRET_NAME=listmonk/postgres-credentials
POSTGRES_USERNAME=listmonk
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DATABASE=listmonk
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Listmonk Application Configuration
LISTMONK_SECRET_NAME=listmonk/app-secrets
LISTMONK_ADMIN_USERNAME=admin
LISTMONK_ADMIN_PASSWORD=your_admin_password_here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here
FROM_EMAIL=noreply@listmonk.local